@model List<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Bài viết";
}

<h2>Danh sách bài viết</h2>

<div class="row">
    @foreach (var post in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(post.ImageUrl))
                {
                    <img src="@post.ImageUrl" class="card-img-top" style="height:200px; object-fit:cover;" />
                }
                <div class="card-body">
                    <h5 class="card-title">@post.Title</h5>
                    <p class="card-text">
                        <small class="text-muted">Danh mục: @(post.Category?.Name ?? "Chưa phân loại")</small><br />
                        <small class="text-muted">Ngày đăng: @post.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </p>
                    <p class="card-text">@(post.Content?.Length > 100 ? post.Content.Substring(0, 100) + "..." : post.Content)</p>
                    <a asp-action="Details" asp-route-id="@post.Id" class="btn btn-primary">Đọc tiếp</a>
                </div>
            </div>
        </div>
    }
</div>