@model UpdatePostDTO
@{
    ViewData["Title"] = "Refine Narrative";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-4xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Content Refinement</h3>
            <p class="serif text-3xl font-bold">Edit Editorial Story</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Back to Stories
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Title (English)</label>
                <input asp-for="TitleEn" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold" required />
                <span asp-validation-for="TitleEn" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Title (Vietnamese)</label>
                <input asp-for="TitleVi" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold" required />
                <span asp-validation-for="TitleVi" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Slug (English)</label>
                <input asp-for="SlugEn" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="how-to-choose-perfume" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Slug (Vietnamese)</label>
                <input asp-for="SlugVi" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="cach-chon-nuoc-hoa" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Editorial Category</label>
                <select asp-for="CategoryId" asp-items="ViewBag.CategoryList" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 text-label-sm uppercase tracking-widest"></select>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Update Visual Asset</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl" class="h-20 w-auto border border-outline-variant object-cover" />
                    </div>
                }
                <input type="file" name="uploadImage" class="w-full text-label-sm uppercase tracking-widest file:mr-lg file:py-2 file:px-lg file:border-0 file:bg-primary file:text-on-primary hover:file:bg-neutral-800" />
                <p class="text-[10px] text-outline uppercase tracking-widest italic">Leave empty to preserve existing visual asset.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Content (English)</label>
                <textarea asp-for="ContentEn" id="editorEn" rows="12" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg leading-relaxed italic serif"></textarea>
                <span asp-validation-for="ContentEn" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Content (Vietnamese)</label>
                <textarea asp-for="ContentVi" id="editorVi" rows="12" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg leading-relaxed italic serif"></textarea>
                <span asp-validation-for="ContentVi" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Summary (English) <span class="text-outline italic normal-case font-normal text-xs">(auto-generated from content if left empty)</span></label>
                <textarea asp-for="SummaryEn" rows="3" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-md leading-relaxed" placeholder="Brief excerpt for preview cards..."></textarea>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Summary (Vietnamese) <span class="text-outline italic normal-case font-normal text-xs">(tự động tạo từ nội dung nếu bỏ trống)</span></label>
                <textarea asp-for="SummaryVi" rows="3" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-md leading-relaxed" placeholder="Mô tả ngắn cho thẻ xem trước..."></textarea>
            </div>
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Save Refinements
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Discard Changes
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    <script>
        class UploadAdapter {
            constructor(loader) { this.loader = loader; }
            upload() {
                return this.loader.file.then(file => new Promise((resolve, reject) => {
                    const data = new FormData();
                    data.append('upload', file);
                    fetch('/Post/UploadImage', { method: 'POST', body: data })
                        .then(r => r.json())
                        .then(r => { if (r.uploaded) resolve({ default: r.url }); else reject(r.error?.message || 'Upload failed'); })
                        .catch(reject);
                }));
            }
            abort() {}
        }
        function UploadAdapterPlugin(editor) {
            editor.plugins.get('FileRepository').createUploadAdapter = loader => new UploadAdapter(loader);
        }
        ['editorEn', 'editorVi'].forEach(function(id) {
            const el = document.querySelector('#' + id);
            if (el) {
                ClassicEditor
                    .create(el, {
                        extraPlugins: [UploadAdapterPlugin],
                        toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'blockQuote', 'insertTable', '|', 'undo', 'redo', 'imageUpload'],
                    })
                    .catch(console.error);
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
