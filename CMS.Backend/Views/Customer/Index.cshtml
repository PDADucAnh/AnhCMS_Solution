@model List<CMS.Data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">DANH SÁCH KHÁCH HÀNG</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm khách hàng mới
        </a>
    </div>

    @if (Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th style="width: 60px;">ID</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th style="width: 120px;">Điện thoại</th>
                        <th>Địa chỉ</th>
                        <th style="width: 150px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="text-center">@c.Id</td>
                            <td><strong>@c.FullName</strong></td>
                            <td>@c.Email</td>
                            <td>@c.Phone</td>
                            <td>@c.Address</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-warning" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-danger" title="Xóa"
                                   onclick="return confirm('Xóa khách hàng này?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Chưa có khách hàng nào.
            <a asp-action="Create">Thêm mới</a>
        </div>
    }
</div>