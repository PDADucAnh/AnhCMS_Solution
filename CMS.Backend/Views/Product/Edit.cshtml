@model UpdateProductDTO
@{
    ViewData["Title"] = "Refine Item";
    Layout = "_LayoutAdmin";
}

<div class="space-y-lg max-w-4xl mx-auto">
    <div class="flex justify-between items-center">
        <div>
            <h3 class="text-label-sm uppercase tracking-[0.3em] text-secondary">Inventory Refinement</h3>
            <p class="serif text-3xl font-bold">Edit Luxury Product</p>
        </div>
        <a asp-action="Index" class="text-label-sm uppercase tracking-widest font-bold flex items-center gap-2 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-lg">arrow_back</span>
            Back to Collection
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="bg-surface-container-lowest border border-outline-variant p-xl space-y-xl">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Name (English)</label>
                <input asp-for="NameEn" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold" required />
                <span asp-validation-for="NameEn" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Name (Vietnamese)</label>
                <input asp-for="NameVi" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 serif text-2xl font-bold" required />
                <span asp-validation-for="NameVi" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Slug (English)</label>
                <input asp-for="SlugEn" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="product-name" />
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Slug (Vietnamese)</label>
                <input asp-for="SlugVi" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3" placeholder="ten-san-pham" />
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Collection Division</label>
                <select asp-for="CategoryProductId" asp-items="ViewBag.CategoryProductList" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 text-label-sm uppercase tracking-widest"></select>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Update Visual Representation</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ImageUrl" class="h-20 w-auto border border-outline-variant object-cover" />
                    </div>
                }
                <input type="file" name="uploadImage" class="w-full text-label-sm uppercase tracking-widest file:mr-lg file:py-2 file:px-lg file:border-0 file:bg-primary file:text-on-primary hover:file:bg-neutral-800" />
                <p class="text-[10px] text-outline uppercase tracking-widest italic">Leave empty to preserve existing visual asset.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Acquisition Value (VNĐ)</label>
                <input asp-for="Price" type="text" inputmode="numeric" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 font-bold serif text-xl" required />
                <span asp-validation-for="Price" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Inventory Manifest Quantity</label>
                <input asp-for="StockQuantity" type="number" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-3 font-bold serif text-xl" required />
                <span asp-validation-for="StockQuantity" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Description (English)</label>
                <textarea asp-for="DescriptionEn" rows="6" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg leading-relaxed italic serif"></textarea>
                <span asp-validation-for="DescriptionEn" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
            <div class="space-y-md">
                <label class="text-label-sm uppercase tracking-widest text-secondary font-bold">Description (Vietnamese)</label>
                <textarea asp-for="DescriptionVi" rows="6" class="w-full bg-surface-container-low border-none focus:ring-1 focus:ring-primary px-lg py-4 text-body-lg leading-relaxed italic serif"></textarea>
                <span asp-validation-for="DescriptionVi" class="text-error text-xs uppercase tracking-widest"></span>
            </div>
        </div>

        <div class="pt-lg border-t border-outline-variant flex gap-md">
            <button type="submit" class="bg-primary text-on-primary px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-neutral-800 transition-all flex-1">
                Save Refinements
            </button>
            <a asp-action="Index" class="border border-outline px-xl py-4 text-label-sm uppercase tracking-[0.2em] font-bold hover:bg-surface-container transition-all">
                Discard Changes
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function formatPriceInput(input) {
            let val = input.value.replace(/\s/g, '');
            if (val) {
                input.value = val.replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
            }
        }
        document.addEventListener('DOMContentLoaded', function() {
            var priceInput = document.getElementById('Price');
            if (priceInput) {
                formatPriceInput(priceInput);
                priceInput.addEventListener('input', function() { formatPriceInput(this); });
                priceInput.closest('form').addEventListener('submit', function() {
                    priceInput.value = priceInput.value.replace(/\s/g, '');
                });
            }
        });
    </script>
}
