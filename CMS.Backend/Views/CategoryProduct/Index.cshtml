@model List<CMS.Data.Entities.CategoryProduct>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Danh mục sản phẩm";
}

<div class="container mt-4">
    <h2 class="text-primary mb-4">DANH SÁCH DANH MỤC SẢN PHẨM</h2>

    <a asp-action="Create" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Thêm danh mục mới
    </a>

    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th style="width: 60px;">ID</th>
                    <th>Tên danh mục</th>
                    <th>Mô tả</th>
                    <th style="width: 180px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>@cat.Id</td>
                        <td><strong>@cat.Name</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(cat.Description))
                            {
                                <small>@(cat.Description.Length > 100 ? cat.Description.Substring(0, 100) + "..." : cat.Description)</small>
                            }
                            else
                            {
                                <span class="text-muted">Không có mô tả</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Chưa có danh mục nào. <a asp-action="Create">Thêm danh mục mới</a>
        </div>
    }
</div>