@model List<CMS.Data.Entities.Order>

@{
	Layout = "_LayoutAdmin";
	ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="text-primary">DANH SÁCH ĐƠN HÀNG</h2>
		<a asp-action="Create" class="btn btn-success">
			<i class="bi bi-plus-circle"></i> Thêm đơn hàng mới
		</a>
	</div>

	@if (Model.Count > 0)
	{
		<div class="table-responsive">
			<table class="table table-bordered table-hover">
				<thead class="table-light">
					<tr>
						<th style="width: 60px;">ID</th>
						<th>Khách hàng</th>
						<th style="width: 150px;">Ngày đặt</th>
						<th style="width: 120px;">Trạng thái</th>
						<th>Ghi chú</th>
						<th style="width: 200px;">Thao tác</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var order in Model)
					{
						<tr>
							<td class="text-center">
								<span class="badge bg-primary">@order.Id</span>
							</td>
							<td><strong>@(order.Customer?.FullName ?? "Không xác định")</strong></td>
							<td class="text-center">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
							<td class="text-center">
								@switch (order.Status)
								{
									case 0:
										<span class="badge bg-warning">Chờ duyệt</span>
										break;
									case 1:
										<span class="badge bg-info">Đang giao</span>
										break;
									case 2:
										<span class="badge bg-success">Đã xong</span>
										break;
									default:
										<span class="badge bg-secondary">Không rõ</span>
										break;
								}
							</td>
							<td>
								@if (!string.IsNullOrEmpty(order.Notes))
								{
									<span title="@order.Notes">
										@(order.Notes.Length > 30 ? order.Notes.Substring(0, 30) + "..." : order.Notes)
									</span>
								}
								else
								{
									<span class="text-muted">-</span>
								}
							</td>
							<td class="text-center">
								<a asp-action="Edit" asp-route-id="@order.Id"
								   class="btn btn-sm btn-outline-warning" title="Chỉnh sửa">
									<i class="bi bi-pencil"></i> Sửa
								</a>
								<a asp-action="Details" asp-route-id="@order.Id"
								   class="btn btn-sm btn-outline-info" title="Chi tiết">
									<i class="bi bi-eye"></i> Chi tiết
								</a>
								<a asp-action="Delete" asp-route-id="@order.Id"
								   class="btn btn-sm btn-outline-danger" title="Xóa"
								   onclick="return confirm('Xóa đơn hàng này?')">
									<i class="bi bi-trash"></i>
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
	else
	{
		<div class="alert alert-info">
			<i class="bi bi-info-circle"></i> Chưa có đơn hàng nào.
			<a asp-action="Create">Thêm mới</a>
		</div>
	}
</div>
