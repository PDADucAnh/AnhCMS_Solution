@model List<CMS.Data.Entities.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<h2>Danh sách đơn hàng</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Khách hàng</th>
            <th>Ngày đặt</th>
            <th>Trạng thái</th>
            <th>Ghi chú</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@(order.Customer?.FullName ?? "Không xác định")</td>
                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @switch (order.Status)
                    {
                        case 0:
                            <span class="badge bg-warning">Chờ duyệt</span>
                            break;
                        case 1:
                            <span class="badge bg-info">Đang giao</span>
                            break;
                        case 2:
                            <span class="badge bg-success">Đã xong</span>
                            break;
                        default:
                            <span class="badge bg-secondary">Không xác định</span>
                            break;
                    }
                </td>
                <td>@order.Notes</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Sửa</a>
                    <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info">Chi tiết</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Create" class="btn btn-primary">Tạo đơn hàng mới</a>
</div>