@model List<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản lý thành viên";
}

<h2>QUẢN LÝ THÀNH VIÊN</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tên Đăng Nhập</th>
            <th>Họ Và Tên</th>
            <th>Quyền Hạn</th>
            <th>Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Username</td>
                <td>@user.FullName</td>
                <td>@user.Role</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Sửa</a>
                    @* Hiện tại chỉ có Sửa; nếu cần Xóa có thể thêm sau *@
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Create" class="btn btn-primary">Thêm thành viên mới</a>
</div>